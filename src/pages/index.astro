---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- ─── Hero ────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <div class="hero__grid">
        <!-- Copy -->
        <div class="hero__copy">
          <span class="hero__badge">Enterprise AI Agents. Zero-Compromise Privacy.</span>
          <h1 class="hero__title">
            Reliable, citation&#8209;backed answers for<br /><em>Law, Finance & Healthcare</em>
          </h1>
          <p class="hero__sub">
            RAGBase automates complex research, ensures strict data privacy (PII filtering), and delivers hallucination-free insights with verifiable citations for professionals.
          </p>
          <div class="hero__actions">
            <a class="btn btn--primary" href="#consultation">Book a Demo</a>
            <a class="btn btn--outline" href="#how-it-works">See How It Works</a>
          </div>
        </div>

        <!-- Demo Card -->
        <div class="demo-card">
          <div class="demo-card__bar">
            <span class="demo-card__dot demo-card__dot--r"></span>
            <span class="demo-card__dot demo-card__dot--y"></span>
            <span class="demo-card__dot demo-card__dot--g"></span>
          </div>
          <div class="demo-card__body">
            <p class="demo-card__q-label">Question</p>
            <p class="demo-card__question">"What are the reporting requirements for our latest Q3 SEC filing?"</p>

            <p class="demo-card__a-label">Answer</p>
            <ul class="demo-card__answer">
              <li>Detailed MD&A section on revenue changes</li>
              <li>Updates on ongoing regulatory proceedings</li>
              <li>Quantitative risk disclosures (market &amp; credit)</li>
              <li>Signed certifications from CEO and CFO</li>
            </ul>

            <div class="demo-card__sources">
              <span class="demo-card__source-label">Sources</span>
              <span class="demo-card__source-tag">10-Q_Guidelines.pdf</span>
              <span class="demo-card__source-tag">Q3_Draft_Notes.docx</span>
              <span class="demo-card__source-tag" style="background:#e0f2fe; color:#0369a1;">SEC.gov - Form 10-Q</span>
              <span class="demo-card__source-tag" style="background:#e0f2fe; color:#0369a1;">Investopedia - MD&A</span>
              <span class="demo-card__source-tag">Compliance_Manual.pdf</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Social proof -->
      <div class="social-proof">
        <p class="social-proof__label">Trusted by leading enterprises</p>
        <div class="social-proof__logos">
          <span>50+ Enterprise Clients</span>
          <span>150,000+ Documents Ingested</span>
          <span>99.9% Uptime SLA</span>
          <span>9,500+ Cases Processed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Product / Benefits ──────────────────────────── -->
  <section id="product">
    <div class="container">
      <p class="section-label">Enterprise-Grade Intelligence</p>
      <h2 class="section-title">Why Industry Leaders Trust RAGBase</h2>
      <p class="section-sub">A specialized AI platform designed to scale professional expertise securely.</p>

      <div class="benefits__grid">
        <div class="benefit-card reveal">
          <div class="benefit-card__icon">🔒</div>
          <h3 class="benefit-card__title">Zero-Compromise Privacy</h3>
          <p class="benefit-card__desc">Our automated PII Firewall instantly redacts sensitive client data (HIPAA, GDPR) before it ever reaches the reasoning engine. Absolute confidentiality, guaranteed.</p>
        </div>
        <div class="benefit-card reveal reveal-delay-1">
          <div class="benefit-card__icon">📑</div>
          <h3 class="benefit-card__title">Guaranteed Accuracy</h3>
          <p class="benefit-card__desc">Eliminate tedious review cycles. An independent AI auditor cross-references every claim against your raw data, delivering 100% verified answers with clickable line-by-line citations.</p>
        </div>
        <div class="benefit-card reveal reveal-delay-2">
          <div class="benefit-card__icon">🧠</div>
          <h3 class="benefit-card__title">Context-Aware Intelligence</h3>
          <p class="benefit-card__desc">Ask complex, multi-layered questions exactly as you would to a senior analyst. RAGBase understands nuance, intent, and jurisdiction to surface the exact strategic insight you need.</p>
        </div>
        <div class="benefit-card reveal reveal-delay-3">
          <div class="benefit-card__icon">⚡</div>
          <h3 class="benefit-card__title">Frictionless Onboarding</h3>
          <p class="benefit-card__desc">Connect your scattered enterprise data in minutes. We automatically process complex PDFs, scanned reports, and internal manuals without losing critical document structure.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── How It Works ────────────────────────────────── -->
  <section id="how-it-works">
    <div class="container">
      <p class="section-label text-center">The RAGBase Workflow</p>
      <h2 class="section-title text-center mx-auto" style="max-width:640px">From Raw Data to Verified Insights in Seconds.</h2>

      <div class="steps">
        <div class="steps__grid">
          <div class="step reveal">
            <span class="step__number">1</span>
            <h3 class="step__title">Secure Data Ingestion</h3>
            <p class="step__desc">Upload your sensitive documents with confidence. Our PII Firewall sanitizes all personal data before any AI processing begins.</p>
          </div>
          <div class="step reveal reveal-delay-1">
            <span class="step__number">2</span>
            <h3 class="step__title">Intelligent Reasoning</h3>
            <p class="step__desc">The AI acts as your senior researcher, instantly reading through thousands of pages to understand context, identify precedents, and extract key facts.</p>
          </div>
          <div class="step reveal reveal-delay-2">
            <span class="step__number">3</span>
            <h3 class="step__title">Audit-Ready Delivery</h3>
            <p class="step__desc">Receive a comprehensively drafted memo or answer. Every single claim is independently audited by the AI and linked directly to the original source.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Use Cases ───────────────────────────────────── -->
  <section id="use-cases">
    <div class="container">
      <p class="section-label">Solutions</p>
      <h2 class="section-title">Built for professional workflows</h2>
      <p class="section-sub">RAGBase adapts to strict compliance and expert operational standards.</p>

      <div class="use-cases__grid">
        <div class="use-case-card reveal">
          <h3 class="use-case-card__title">Legal: Case Law &amp; Contracts</h3>
          <p class="use-case-card__desc">Quickly pull together supporting evidence, legal precedents, and contract analysis without breaching Attorney-Client Privilege. RAGBase surfaces exact clauses you need and links back to source files.</p>
        </div>
        <div class="use-case-card reveal reveal-delay-1">
          <h3 class="use-case-card__title">Financial: Filings &amp; Research</h3>
          <p class="use-case-card__desc">Ask complex questions regarding SEC filings, market research reports, and historical financial metrics. Get a grounded answer referencing specific tables and statements securely.</p>
        </div>
        <div class="use-case-card reveal reveal-delay-2">
          <h3 class="use-case-card__title">Healthcare: Patient Records</h3>
          <p class="use-case-card__desc">Review HIPAA-compliant patient files and medical histories efficiently. The PII layer ensures sensitive medical data is anonymized while you extract factual diagnostic histories.</p>
        </div>
        <div class="use-case-card reveal reveal-delay-3">
          <h3 class="use-case-card__title">Cross-Industry: Compliance</h3>
          <p class="use-case-card__desc">Verify your internal operations meet every requirement by cross-referencing company checklists, regulatory updates, and policy manuals — all in one trusted query.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Pricing ─────────────────────────────────────── -->
  <section id="pricing">
    <div class="container">
      <p class="section-label text-center">Pricing</p>
      <h2 class="section-title text-center">Simple, transparent pricing</h2>
      <p class="section-sub text-center mx-auto">Start small and scale as your organization grows. No hidden fees.</p>

      <div class="pricing__grid">
        <!-- Starter -->
        <div class="price-card reveal">
          <p class="price-card__name">Starter</p>
          <div class="price-card__price">
            <span class="price-card__amount">$3,000</span>
            <span class="price-card__period">/year</span>
          </div>
          <ul class="price-card__features">
            <li>500 searches/month</li>
            <li>Single-Agent RAG</li>
            <li>Basic PII Redaction</li>
            <li>Direct Hybrid Search</li>
          </ul>
        </div>

        <!-- Pro -->
        <div class="price-card price-card--popular reveal reveal-delay-1">
          <span class="price-card__badge">Recommended</span>
          <p class="price-card__name">Professional</p>
          <div class="price-card__price">
            <span class="price-card__amount">$9,000</span>
            <span class="price-card__period">/year</span>
          </div>
          <ul class="price-card__features">
            <li>5,000 searches/month</li>
            <li>Multi-Agent Orchestration</li>
            <li>HIPAA/GDPR Compliance</li>
            <li>Evaluation Agent (Anti-Hallucination)</li>
          </ul>
        </div>

        <!-- Enterprise -->
        <div class="price-card reveal reveal-delay-2">
          <p class="price-card__name">Enterprise</p>
          <div class="price-card__price">
            <span class="price-card__amount">Custom</span>
          </div>
          <ul class="price-card__features">
            <li>Unlimited searches/month</li>
            <li>Custom Multi-Agent Swarms</li>
            <li>On-premise / Private Cloud</li>
            <li>24/7 Support &amp; 99.9% SLA</li>
          </ul>
        </div>
      </div>

      <div style="margin-top: 3rem; text-align: center;">
        <a class="btn btn--primary" href="/pricing">View Detailed Feature Comparison</a>
      </div>

      <p class="pricing__note">Pricing shown as placeholder. Contact us for custom enterprise plans.</p>
    </div>
  </section>

  <!-- ─── Consultation Form ───────────────────────────── -->
  <section id="consultation" class="consultation">
    <div class="container">
      <div class="consultation__grid">
        <div class="consultation__text">
          <p class="section-label">Get in Touch</p>
          <h2 class="section-title">Talk to us</h2>
          <p class="section-sub">We'll learn your workflow and recommend the best setup for your organization — no pressure, no obligation.</p>

          <div class="booking-workflow">
            <div class="workflow-step">
              <div class="workflow-step__icon">1</div>
              <div class="workflow-step__content">
                <h4 class="workflow-step__title">Strategic Assessment</h4>
                <p class="workflow-step__desc">Identify high-ROI workflows where our Enterprise AI can instantly eliminate manual research and radically accelerate review cycles.</p>
              </div>
            </div>
            
            <div class="workflow-step">
              <div class="workflow-step__icon">2</div>
              <div class="workflow-step__content">
                <h4 class="workflow-step__title">Live Proof of Value</h4>
                <p class="workflow-step__desc">See the platform in action. We use a secure sandbox to prove 100% verified, hallucination-free answers using your real-world scenarios.</p>
              </div>
            </div>

            <div class="workflow-step">
              <div class="workflow-step__icon">3</div>
              <div class="workflow-step__content">
                <h4 class="workflow-step__title">Accelerated Deployment</h4>
                <p class="workflow-step__desc">Receive a turnkey Multi-Agent blueprint tailored for your scale, ensuring instant adoption, strict compliance, and immediate impact.</p>
              </div>
            </div>
          </div>
        </div>

        <form class="form" id="consultationForm">
          <div class="form__group">
            <label for="formName">Name</label>
            <input type="text" id="formName" name="name" placeholder="Jane Doe" required />
          </div>
          <div class="form__group">
            <label for="formPhone">Phone Number</label>
            <input type="tel" id="formPhone" name="phone" placeholder="(555) 123-4567" required />
          </div>
          <div class="form__group">
            <label for="formEmail">Email</label>
            <input type="email" id="formEmail" name="email" placeholder="jane@example.com" required />
          </div>
          <div class="form__group">
            <label for="formOrg">Organization Name</label>
            <input type="text" id="formOrg" name="organization" placeholder="Doe & Partners" required />
          </div>
          <div class="form__group">
            <label for="formMessage">Message</label>
            <textarea id="formMessage" name="message" placeholder="Tell us about your current workflow…" required></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--full" id="submitBtn">Book Free Consultation</button>
        </form>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('consultationForm') as HTMLFormElement | null;
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;

      if (form && submitBtn) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();

          // Basic manual validation just in case HTML5 validation is bypassed
          const nameInput = document.getElementById('formName') as HTMLInputElement | null;
          const phoneInput = document.getElementById('formPhone') as HTMLInputElement | null;
          const emailInput = document.getElementById('formEmail') as HTMLInputElement | null;
          const orgInput = document.getElementById('formOrg') as HTMLInputElement | null;
          const messageInput = document.getElementById('formMessage') as HTMLTextAreaElement | null;

          const name = nameInput?.value.trim() || '';
          const phone = phoneInput?.value.trim() || '';
          const email = emailInput?.value.trim() || '';
          const org = orgInput?.value.trim() || '';
          const message = messageInput?.value.trim() || '';

          if (!name || !phone || !email || !org || !message) {
            alert('Please fill out all required fields.');
            return;
          }

          // Simulate API call / loading state
          submitBtn.textContent = 'Submitting...';
          submitBtn.disabled = true;

          setTimeout(() => {
            window.location.href = '/thank-you';
          }, 1500);
        });
      }
    });
  </script>

  <!-- ─── FAQ ─────────────────────────────────────────── -->
  <section id="faq">
    <div class="container">
      <p class="section-label text-center">FAQ</p>
      <h2 class="section-title text-center">Frequently asked questions</h2>

      <div class="faq__list">
        <details class="accordion__item reveal">
          <summary class="accordion__trigger">What is RAGBase?</summary>
          <div class="accordion__content">
            RAGBase is a specialized enterprise AI platform built for law firms, financial institutions, and healthcare providers. We automate tedious research and drafting tasks so your highly skilled professionals can focus on strategic decision-making.
          </div>
        </details>

        <details class="accordion__item reveal reveal-delay-1">
          <summary class="accordion__trigger">How do you ensure data security and compliance?</summary>
          <div class="accordion__content">
            Security is built into our foundation. Our proprietary PII Firewall strips away sensitive information (like patient names or SSNs) locally before any data is processed for insights. We meet the strictest HIPAA and GDPR standards to protect your firm's liability.
          </div>
        </details>

        <details class="accordion__item reveal reveal-delay-2">
          <summary class="accordion__trigger">How do you prevent AI hallucinations?</summary>
          <div class="accordion__content">
            We use an embedded "Auditor AI" that operates independently. Before an answer is shown to you, it undergoes a strict internal review. If a claim lacks evidence from your uploaded documents, it is automatically rejected and rewritten.
          </div>
        </details>

        <details class="accordion__item reveal reveal-delay-3">
          <summary class="accordion__trigger">Can I verify the AI's answers?</summary>
          <div class="accordion__content">
            Absolutely. Every single factual statement generated by RAGBase includes a direct citation. Clicking it jumps you directly to the exact page, paragraph, and line in your highly-secure original document.
          </div>
        </details>

        <details class="accordion__item reveal reveal-delay-4">
          <summary class="accordion__trigger">How is our data handled?</summary>
          <div class="accordion__content">
            Your documents are encrypted at rest and in transit. We do not use your data to train models. Each workspace is fully isolated, and you retain ownership and control of all uploaded materials.
          </div>
        </details>

        <details class="accordion__item reveal">
          <summary class="accordion__trigger">Does this replace professionals?</summary>
          <div class="accordion__content">
            No. RAGBase is a research tool that helps professionals work faster and more accurately by surfacing relevant information from their own secure documents. All professional judgment and decision-making remain with you.
          </div>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>
